{
  "name": "@easycode/relay-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "migrate:postgres": "tsx src/migrate-postgres.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm build && node --test dist/**/*.test.js",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@easycode/protocol": "workspace:*",
    "pg": "^8.22.0",
    "ws": "^8.18.2"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
